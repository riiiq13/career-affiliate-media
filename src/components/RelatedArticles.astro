---
import { getCollection } from "astro:content";
import ArticleCard from "./ArticleCard.astro";

const { relatedSlugs = [] } = Astro.props as { relatedSlugs: string[] };
const allArticles = await getCollection("articles");
const articles = allArticles.filter((article) => relatedSlugs.includes(article.slug)).slice(0, 3);
---

{articles.length > 0 && (
  <section class="section">
    <div class="section-heading">
      <h2>関連記事</h2>
      <p class="muted">同じ悩みで次に読みたい記事です。</p>
    </div>
    <div class="grid">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
)}
