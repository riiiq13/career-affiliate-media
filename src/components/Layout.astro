---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { buildTitle, site } from "../utils/seo";

interface Props {
  title: string;
  description: string;
  path?: string;
  ogType?: "website" | "article";
  jsonLd?: unknown | unknown[];
  noindex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  ogType = "website",
  jsonLd = [],
  noindex = false
} = Astro.props;
const pageTitle = title.includes(site.name) ? title : buildTitle(title);
const canonical = new URL(path, Astro.site ?? site.url).toString();
const schemaItems = (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).filter(Boolean);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL("/favicon.svg", Astro.site ?? site.url).toString()} />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="google-site-verification" content="SDSevtEUj_1eOIwDsMZthmrR42i5YKHx8vAlpUuxhAc" />
    {schemaItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --color-ink: #17211f;
    --color-muted: #5e6a65;
    --color-paper: #f7faf6;
    --color-surface: #ffffff;
    --color-soft: #eef5ef;
    --color-line: #d8e2db;
    --color-teal: #14635f;
    --color-green: #18443b;
    --color-gold: #f0b84f;
    --color-coral: #d05f45;
    --color-blue: #315f8c;
    --shadow-soft: 0 18px 45px rgba(23, 33, 31, 0.08);
    --radius: 8px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    color: var(--color-ink);
    font-family: "Noto Sans JP", "Hiragino Kaku Gothic ProN", "Yu Gothic", sans-serif;
    line-height: 1.75;
    background:
      linear-gradient(90deg, rgba(20, 99, 95, 0.04) 1px, transparent 1px),
      linear-gradient(180deg, rgba(208, 95, 69, 0.04) 1px, transparent 1px),
      var(--color-paper);
    background-size: 36px 36px;
    letter-spacing: 0;
  }

  a {
    color: var(--color-teal);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  img,
  svg {
    max-width: 100%;
  }

  main {
    min-height: 60vh;
  }

  .container {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .narrow {
    width: min(820px, calc(100% - 32px));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(247, 250, 246, 0.94);
    border-bottom: 1px solid var(--color-line);
    backdrop-filter: blur(14px);
  }

  .site-header__inner,
  .site-footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-ink);
    font-weight: 800;
    text-decoration: none;
  }

  .brand__mark {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    color: #fff;
    background: var(--color-green);
    font-weight: 900;
  }

  .site-nav,
  .footer-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
  }

  .site-nav a,
  .footer-nav a {
    color: var(--color-ink);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .site-nav a:hover,
  .footer-nav a:hover {
    color: var(--color-coral);
  }

  .hero {
    position: relative;
    overflow: hidden;
    color: #fff;
    background:
      linear-gradient(120deg, rgba(20, 49, 43, 0.98) 0%, rgba(20, 99, 95, 0.94) 54%, rgba(208, 95, 69, 0.92) 100%),
      repeating-linear-gradient(45deg, rgba(255,255,255,0.12) 0 1px, transparent 1px 18px);
    padding: 84px 0 72px;
  }

  .hero::after {
    content: "";
    position: absolute;
    right: 8%;
    bottom: -20px;
    width: 280px;
    height: 180px;
    border: 1px solid rgba(255, 255, 255, 0.34);
    transform: rotate(-6deg);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: min(820px, 100%);
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--color-gold);
    font-weight: 800;
    font-size: 0.9rem;
  }

  h1,
  h2,
  h3 {
    line-height: 1.35;
    letter-spacing: 0;
  }

  h1 {
    margin: 0 0 20px;
    font-size: clamp(2.1rem, 5vw, 4.3rem);
  }

  h2 {
    margin: 0 0 14px;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
  }

  h3 {
    margin: 0 0 10px;
    font-size: 1.15rem;
  }

  p {
    margin: 0 0 1rem;
  }

  .lead {
    font-size: 1.08rem;
    color: inherit;
  }

  .section {
    padding: 58px 0;
  }

  .section--soft {
    background: rgba(238, 245, 239, 0.68);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .grid--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card,
  .article-card,
  .notice,
  .cta-box,
  .diagnosis-panel,
  .faq-block details {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .card,
  .article-card,
  .notice,
  .diagnosis-panel {
    padding: 22px;
  }

  .article-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    gap: 10px;
  }

  .article-card__category {
    color: var(--color-coral);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .article-card h3 a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .article-card p {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 20px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 16px;
    border: 1px solid transparent;
    border-radius: 6px;
    color: #fff;
    background: var(--color-teal);
    font-weight: 800;
    text-decoration: none;
  }

  .button:hover {
    background: var(--color-green);
  }

  .button--secondary {
    color: var(--color-ink);
    background: #fff;
    border-color: var(--color-line);
  }

  .button--secondary:hover {
    color: #fff;
    background: var(--color-blue);
  }

  .breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 22px 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .breadcrumbs a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .affiliate-disclosure {
    margin: 18px 0;
    padding: 14px 16px;
    border-left: 4px solid var(--color-gold);
    background: #fff9e8;
    color: #59461d;
    font-size: 0.92rem;
  }

  .article-shell {
    padding: 30px 0 70px;
  }

  .article-header {
    padding: 36px 0 22px;
    border-bottom: 1px solid var(--color-line);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--color-muted);
    font-size: 0.92rem;
  }

  .article-body {
    width: min(800px, 100%);
    margin: 34px auto 0;
  }

  .article-body h2 {
    margin-top: 42px;
    padding-top: 18px;
    border-top: 1px solid var(--color-line);
  }

  .article-body table,
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    margin: 18px 0 26px;
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--color-line);
  }

  .article-body th,
  .article-body td,
  .comparison-table th,
  .comparison-table td {
    padding: 12px;
    border: 1px solid var(--color-line);
    text-align: left;
    vertical-align: top;
  }

  .article-body th,
  .comparison-table th {
    background: var(--color-soft);
  }

  .cta-box {
    padding: 24px;
    border-left: 5px solid var(--color-teal);
  }

  .cta-box p:last-child,
  .notice p:last-child {
    margin-bottom: 0;
  }

  .faq-block {
    display: grid;
    gap: 12px;
  }

  .faq-block details {
    padding: 16px 18px;
  }

  .faq-block summary {
    cursor: pointer;
    font-weight: 800;
  }

  .category-hero {
    padding: 62px 0 46px;
    color: #fff;
    background: var(--color-green);
  }

  .site-footer {
    border-top: 1px solid var(--color-line);
    background: #fff;
  }

  .site-footer__inner {
    align-items: flex-start;
    padding: 34px 0;
  }

  .muted {
    color: var(--color-muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
    margin: 16px 0 0;
    list-style: none;
  }

  .tag-list li {
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--color-soft);
    color: var(--color-green);
    font-size: 0.88rem;
    font-weight: 700;
  }

  @media (max-width: 820px) {
    .site-header__inner,
    .site-footer__inner,
    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .grid,
    .grid--2 {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: 60px 0 50px;
    }

    .site-nav {
      width: 100%;
      gap: 10px;
    }

    .site-nav a {
      font-size: 0.86rem;
    }

    .article-body {
      width: 100%;
    }

    .article-body table,
    .comparison-table {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>
