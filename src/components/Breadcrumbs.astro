---
type Item = {
  label: string;
  href?: string;
};

const { items = [] } = Astro.props as { items: Item[] };
---

<nav class="breadcrumbs" aria-label="パンくずリスト">
  {items.map((item, index) => (
    <>
      {index > 0 && <span aria-hidden="true">/</span>}
      {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
    </>
  ))}
</nav>
